"""
name_normalization_utils
------------------------

This module provides helper functions for normalizing human names when
you already have predicted first, middle and last name values, but those
components may sometimes be jumbled or interchanged.

Examples:
- "Doe John" may need to become first="John", last="Doe"
- "John A. Doe" should become first="John", middle="A.", last="Doe"

The module uses two dedicated name parsers:

* probablepeople
  A probabilistic parser that labels tokens such as GivenName and
  Surname. It is useful for tricky or less structured name strings.

* nameparser
  A rule-based parser that supports patterns like:
  - "Title First Middle Last"
  - "Last, First"

The functions are designed to work as follows:

1. If you already have a full name string, call `normalize_name(name)`.
2. If you already have predicted first/middle/last fields and want to
   fix possible swaps, call:
   `correct_name_components(first_guess, middle_guess, last_guess)`.

If `probablepeople` is available, it is tried first.
If that does not work, `nameparser` is used.
If both are unavailable or fail, a simple heuristic fallback is used.
"""

from __future__ import annotations

from typing import Dict, List

try:
    import probablepeople  # type: ignore
except ImportError:
    probablepeople = None  # type: ignore

try:
    from nameparser import HumanName  # type: ignore
except ImportError:
    HumanName = None  # type: ignore


def _clean_text(value: str) -> str:
    return " ".join(str(value).replace("\n", " ").strip().split())


def _parse_with_probablepeople(name: str) -> Dict[str, str]:
    """
    Attempt to parse a name using probablepeople.

    Returns a dictionary with keys `first`, `middle`, and `last` if
    successful. Otherwise returns an empty dict.
    """
    if probablepeople is None:
        return {}

    try:
        parsed = probablepeople.parse(name)
    except Exception:
        return {}

    parts: Dict[str, List[str]] = {}

    for token, tag in parsed:
        token = _clean_text(token)
        if not token:
            continue

        if tag == "GivenName":
            if "first" not in parts:
                parts.setdefault("first", []).append(token)
            else:
                parts.setdefault("middle", []).append(token)

        elif tag in {"MiddleName", "MiddleInitial", "SecondGivenName"}:
            parts.setdefault("middle", []).append(token)

        elif tag == "Surname":
            parts.setdefault("last", []).append(token)

    if parts.get("first") or parts.get("last"):
        return {
            "first": " ".join(parts.get("first", [])),
            "middle": " ".join(parts.get("middle", [])),
            "last": " ".join(parts.get("last", [])),
        }

    return {}


def _parse_with_nameparser(name: str) -> Dict[str, str]:
    """
    Parse a name using nameparser.HumanName.

    Returns a dict with keys `first`, `middle`, and `last`.
    If nameparser is not installed or parsing fails, returns an empty dict.
    """
    if HumanName is None:
        return {}

    try:
        hn = HumanName(name)
    except Exception:
        return {}

    first = _clean_text(hn.first)
    middle = _clean_text(hn.middle)
    last = _clean_text(hn.last)

    if first or last:
        return {
            "first": first,
            "middle": middle,
            "last": last,
        }

    return {}


def _heuristic_parse(name: str) -> Dict[str, str]:
    """
    Very simple fallback parser.

    Rules:
    - If format is "Last, First Middle", split on comma
    - If 1 token: treat as first
    - If 2 tokens: treat as first last
    - If 3+ tokens: first / middle / last
    """
    name = _clean_text(name)
    if not name:
        return {"first": "", "middle": "", "last": ""}

    if "," in name:
        left, right = name.split(",", 1)
        left = _clean_text(left)
        right = _clean_text(right)

        right_tokens = right.split()
        if len(right_tokens) == 0:
            return {"first": "", "middle": "", "last": left}
        if len(right_tokens) == 1:
            return {"first": right_tokens[0], "middle": "", "last": left}

        return {
            "first": right_tokens[0],
            "middle": " ".join(right_tokens[1:]),
            "last": left,
        }

    tokens = name.split()

    if len(tokens) == 1:
        return {"first": tokens[0], "middle": "", "last": ""}

    if len(tokens) == 2:
        return {"first": tokens[0], "middle": "", "last": tokens[1]}

    return {
        "first": tokens[0],
        "middle": " ".join(tokens[1:-1]),
        "last": tokens[-1],
    }


def normalize_name(name: str) -> Dict[str, str]:
    """
    Split a full name string into first, middle, and last parts.

    Parsing order:
    1. probablepeople
    2. nameparser
    3. simple heuristic fallback
    """
    name = _clean_text(name)
    if not name:
        return {"first": "", "middle": "", "last": ""}

    result = _parse_with_probablepeople(name)
    if result:
        return result

    result = _parse_with_nameparser(name)
    if result:
        return result

    return _heuristic_parse(name)


def correct_name_components(
    first_guess: str,
    middle_guess: str,
    last_guess: str,
) -> Dict[str, str]:
    """
    Correct potentially jumbled name components.

    This function joins the provided first/middle/last guesses into one
    candidate string and re-parses it using `normalize_name()`.

    Example:
    - first_guess="Doe", middle_guess="", last_guess="John"
      -> candidate="Doe John"
      -> result may become first="John", last="Doe"
    """
    parts = [
        _clean_text(first_guess),
        _clean_text(middle_guess),
        _clean_text(last_guess),
    ]
    parts = [p for p in parts if p]

    if not parts:
        return {"first": "", "middle": "", "last": ""}

    candidate = " ".join(parts)
    result = normalize_name(candidate)

    if not result or (not result.get("first") and not result.get("last")):
        return {"first": "", "middle": "", "last": candidate}

    return result


__all__ = [
    "normalize_name",
    "correct_name_components",
]
