from typing import List
from pydantic import BaseModel, ConfigDict, Field, StrictBool, StrictInt, StrictStr


class EncounterNameResult(BaseModel):
    model_config = ConfigDict(extra="forbid")

    encounter: StrictInt = Field(..., description="Encounter identifier from the input record.")
    flag: StrictBool = Field(
        ...,
        description="True if the input name fields are incorrect and need correction, otherwise False."
    )
    reason: StrictStr = Field(
        ...,
        description='Brief reason. Expected to be "" when flag is False.'
    )
    corrected_first_name: StrictStr = Field(
        ...,
        description="Corrected first name for this encounter."
    )
    corrected_middle_name: StrictStr = Field(
        ...,
        description="Corrected middle name for this encounter."
    )
    corrected_last_name: StrictStr = Field(
        ...,
        description="Corrected last name for this encounter."
    )


class BatchNameCorrectionOutput(BaseModel):
    model_config = ConfigDict(extra="forbid")

    results: List[EncounterNameResult] = Field(
        ...,
        description="One result per input encounter."
    )





import asyncio
import json
import pandas as pd
