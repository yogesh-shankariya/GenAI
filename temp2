from typing import List
from pydantic import BaseModel, ConfigDict, Field, StrictBool, StrictInt, StrictStr


class DistinctNameReviewInput(BaseModel):
    model_config = ConfigDict(extra="forbid")

    name_id: StrictInt = Field(..., description="Stable identifier for this distinct name record.")
    first_name: StrictStr = Field(..., description="Input first name.")
    middle_name: StrictStr = Field(..., description="Input middle name.")
    last_name: StrictStr = Field(..., description="Input last name.")
    occurrence_count: StrictInt = Field(..., description="Count of how many times this exact name combination appeared in the file.")


class DistinctNameBatchInput(BaseModel):
    model_config = ConfigDict(extra="forbid")

    records: List[DistinctNameReviewInput] = Field(
        ...,
        description="Distinct name combinations for one file, sorted by occurrence_count descending."
    )


class DistinctNameReviewResult(BaseModel):
    model_config = ConfigDict(extra="forbid")

    name_id: StrictInt = Field(..., description="Same identifier as input.")
    flag: StrictBool = Field(..., description="True if correction is needed, otherwise False.")
    reason: StrictStr = Field(..., description='Brief reason. Expected to be "" when flag is False.')
    corrected_first_name: StrictStr = Field(..., description="Corrected first name.")
    corrected_middle_name: StrictStr = Field(..., description="Corrected middle name.")
    corrected_last_name: StrictStr = Field(..., description="Corrected last name.")


class DistinctNameBatchOutput(BaseModel):
    model_config = ConfigDict(extra="forbid")

    results: List[DistinctNameReviewResult] = Field(
        ...,
        description="One result for each input distinct-name record."
    )






import os
import json
import asyncio
import pandas as pd
from tqdm.auto import tqdm


BATCH_SIZE = 10
MAX_CONCURRENT_REQUESTS = 5


def _safe_str(value):
    if pd.isna(value):
        return ""
    return str(value)


def _to_dict(response):
    if hasattr(response, "model_dump"):
        return response.model_dump()
    return response


def _chunk_records(records, chunk_size):
    for i in range(0, len(records), chunk_size):
        yield records[i:i + chunk_size]


def _append_jsonl(path, records):
    os.makedirs(os.path.dirname(path) or ".", exist_ok=True)
    with open(path, "a", encoding="utf-8") as f:
        for record in records:
            f.write(json.dumps(record, ensure_ascii=False) + "\n")
        f.flush()
        os.fsync(f.fileno())


def _load_jsonl(path):
    if not os.path.exists(path):
        return []

    rows = []
    with open(path, "r", encoding="utf-8") as f:
        for line in f:
            line = line.strip()
            if line:
                rows.append(json.loads(line))
    return rows


def _load_checkpoint_df(path):
    rows = _load_jsonl(path)
    if not rows:
        return pd.DataFrame(
            columns=[
                "record_key",
                "file",
                "name_id",
                "flag",
                "reason",
                "corrected_first_name",
                "corrected_middle_name",
                "corrected_last_name",
            ]
        )

    checkpoint_df = pd.DataFrame(rows)

    if "record_key" not in checkpoint_df.columns:
        raise ValueError("Checkpoint file is missing 'record_key' column")

    checkpoint_df = checkpoint_df.drop_duplicates(subset=["record_key"], keep="last")
    return checkpoint_df


def build_distinct_name_df(df: pd.DataFrame) -> pd.DataFrame:
    required_cols = ["file", "encounter", "first_name", "middle_name", "last_name"]
    missing_cols = [c for c in required_cols if c not in df.columns]
    if missing_cols:
        raise ValueError(f"Missing required columns: {missing_cols}")

    working_df = df.copy().reset_index(drop=False).rename(columns={"index": "_source_row"})

    working_df["file"] = working_df["file"].astype(str)
    working_df["first_name"] = working_df["first_name"].map(_safe_str)
    working_df["middle_name"] = working_df["middle_name"].map(_safe_str)
    working_df["last_name"] = working_df["last_name"].map(_safe_str)

    distinct_df = (
        working_df.groupby(
            ["file", "first_name", "middle_name", "last_name"],
            dropna=False,
            as_index=False
        )
        .agg(
            occurrence_count=("encounter", "size"),
            first_seen_row=("_source_row", "min"),
        )
        .sort_values(
            ["file", "occurrence_count", "first_seen_row"],
            ascending=[True, False, True]
        )
        .reset_index(drop=True)
    )

    distinct_df["name_id"] = distinct_df.groupby("file").cumcount() + 1
    distinct_df["record_key"] = (
        distinct_df["file"].astype(str) + "|" + distinct_df["name_id"].astype(int).astype(str)
    )

    return distinct_df[
        ["record_key", "file", "name_id", "first_name", "middle_name", "last_name", "occurrence_count"]
    ].copy()


def build_batch_prompt(rows):
    payload = {
        "records": [
            {
                "name_id": int(row["name_id"]),
                "first_name": _safe_str(row["first_name"]),
                "middle_name": _safe_str(row["middle_name"]),
                "last_name": _safe_str(row["last_name"]),
                "occurrence_count": int(row["occurrence_count"]),
            }
            for row in rows
        ]
    }

    return PROMPT_TMPL_BATCH.replace(
        "{Input}",
        json.dumps(payload, ensure_ascii=False, indent=2)
    )


async def review_distinct_batch(rows):
    prompt = build_batch_prompt(rows)

    response = await _call_llm_with_retry(
        hclient=hclient,
        schema=DistinctNameBatchOutput,
        prompt=prompt,
        params={"qos": "accurate", "reasoning": "true"},
    )

    response = _to_dict(response)

    if "results" not in response:
        raise ValueError("LLM response does not contain 'results'")

    result_by_name_id = {}
    for item in response["results"]:
        name_id = int(item["name_id"])
        result_by_name_id[name_id] = item

    ordered_results = []
    for row in rows:
        name_id = int(row["name_id"])
        if name_id not in result_by_name_id:
            raise ValueError(f"Missing name_id {name_id} in batch response")
        ordered_results.append(result_by_name_id[name_id])

    return ordered_results


async def review_distinct_batch_safe(rows):
    try:
        batch_results = await review_distinct_batch(rows)
        return {
            "ok": True,
            "rows": rows,
            "batch_results": batch_results,
            "error": None,
        }
    except Exception as e:
        return {
            "ok": False,
            "rows": rows,
            "batch_results": None,
            "error": str(e),
        }


def create_anchor_batches_for_file_with_resume(
    file_full_df: pd.DataFrame,
    completed_keys: set,
    batch_size: int = 10,
):
    records = file_full_df.to_dict("records")
    if not records:
        return []

    if batch_size < 2:
        raise ValueError("batch_size must be at least 2 for anchor batching")

    anchor = records[0]
    anchor_key = anchor["record_key"]

    pending_records = [r for r in records if r["record_key"] not in completed_keys]
    if not pending_records:
        return []

    batches = []

    if anchor_key in {r["record_key"] for r in pending_records}:
        first_batch = pending_records[:batch_size]
        batches.append(first_batch)
        remaining = pending_records[batch_size:]

        for chunk in _chunk_records(remaining, batch_size - 1):
            batches.append([anchor] + chunk)
    else:
        for chunk in _chunk_records(pending_records, batch_size - 1):
            batches.append([anchor] + chunk)

    return batches


async def process_distinct_names_with_majority_anchor_resume(
    df: pd.DataFrame,
    batch_size: int = 10,
    max_concurrent_requests: int = 5,
    checkpoint_path: str = "distinct_name_audit_checkpoint.jsonl",
    failed_batches_path: str = "distinct_name_audit_failed_batches.jsonl",
):
    distinct_df = build_distinct_name_df(df)

    checkpoint_df = _load_checkpoint_df(checkpoint_path)
    completed_keys = set(checkpoint_df["record_key"].tolist())

    print(f"Total distinct rows: {len(distinct_df)}")
    print(f"Already completed from checkpoint: {len(completed_keys)}")
    print(f"Pending distinct rows: {len(distinct_df[~distinct_df['record_key'].isin(completed_keys)])}")

    grouped = distinct_df.groupby("file", sort=False, dropna=False)
    total_files = distinct_df["file"].nunique(dropna=False)

    for file_id, file_df in tqdm(grouped, total=total_files, desc="Files"):
        file_batches = create_anchor_batches_for_file_with_resume(
            file_full_df=file_df,
            completed_keys=completed_keys,
            batch_size=batch_size,
        )

        if not file_batches:
            continue

        for i in range(0, len(file_batches), max_concurrent_requests):
            batch_group = file_batches[i:i + max_concurrent_requests]

            batch_group_results = await asyncio.gather(
                *(review_distinct_batch_safe(batch_rows) for batch_rows in batch_group)
            )

            success_records = []
            failed_records = []

            for result in batch_group_results:
                if result["ok"]:
                    batch_rows = result["rows"]
                    batch_results = result["batch_results"]

                    for input_row, output_row in zip(batch_rows, batch_results):
                        record_key = input_row["record_key"]

                        if record_key in completed_keys:
                            continue

                        success_record = {
                            "record_key": record_key,
                            "file": str(input_row["file"]),
                            "name_id": int(output_row["name_id"]),
                            "flag": output_row["flag"],
                            "reason": output_row["reason"],
                            "corrected_first_name": output_row["corrected_first_name"],
                            "corrected_middle_name": output_row["corrected_middle_name"],
                            "corrected_last_name": output_row["corrected_last_name"],
                        }
                        success_records.append(success_record)
                        completed_keys.add(record_key)
                else:
                    batch_rows = result["rows"]
                    failed_records.append(
                        {
                            "file": str(file_id),
                            "record_keys": [r["record_key"] for r in batch_rows],
                            "name_ids": [int(r["name_id"]) for r in batch_rows],
                            "occurrence_counts": [int(r["occurrence_count"]) for r in batch_rows],
                            "error": result["error"],
                        }
                    )

            if success_records:
                _append_jsonl(checkpoint_path, success_records)

            if failed_records:
                _append_jsonl(failed_batches_path, failed_records)

    checkpoint_df = _load_checkpoint_df(checkpoint_path)

    reviewed_distinct_df = distinct_df.merge(
        checkpoint_df[
            [
                "record_key",
                "flag",
                "reason",
                "corrected_first_name",
                "corrected_middle_name",
                "corrected_last_name",
            ]
        ],
        on="record_key",
        how="left",
    )

    failed_batches_df = pd.DataFrame(_load_jsonl(failed_batches_path))

    return reviewed_distinct_df, failed_batches_df


def merge_distinct_results_back_to_original(
    original_df: pd.DataFrame,
    reviewed_distinct_df: pd.DataFrame
) -> pd.DataFrame:
    working_df = original_df.copy()

    working_df["file"] = working_df["file"].astype(str)
    working_df["first_name"] = working_df["first_name"].map(_safe_str)
    working_df["middle_name"] = working_df["middle_name"].map(_safe_str)
    working_df["last_name"] = working_df["last_name"].map(_safe_str)

    merge_cols = ["file", "first_name", "middle_name", "last_name"]

    result_cols = [
        "name_id",
        "occurrence_count",
        "flag",
        "reason",
        "corrected_first_name",
        "corrected_middle_name",
        "corrected_last_name",
    ]

    final_df = working_df.merge(
        reviewed_distinct_df[merge_cols + result_cols],
        on=merge_cols,
        how="left"
    )

    return final_df


reviewed_distinct_df, failed_batches_df = await process_distinct_names_with_majority_anchor_resume(
    df,
    batch_size=10,
    max_concurrent_requests=5,
    checkpoint_path="distinct_name_audit_checkpoint.jsonl",
    failed_batches_path="distinct_name_audit_failed_batches.jsonl",
)

final_df = merge_distinct_results_back_to_original(df, reviewed_distinct_df)
