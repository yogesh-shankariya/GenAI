import os
import json
import asyncio
import pandas as pd
from tqdm.auto import tqdm


BATCH_SIZE = 10
MAX_CONCURRENT_REQUESTS = 5


def _safe_str(value):
    if pd.isna(value):
        return ""
    return str(value)


def _chunk_records(records, batch_size):
    for i in range(0, len(records), batch_size):
        yield records[i:i + batch_size]


def _to_dict(response):
    if hasattr(response, "model_dump"):
        return response.model_dump()
    return response


def _append_jsonl(path, records):
    os.makedirs(os.path.dirname(path) or ".", exist_ok=True)
    with open(path, "a", encoding="utf-8") as f:
        for record in records:
            f.write(json.dumps(record, ensure_ascii=False) + "\n")
        f.flush()
        os.fsync(f.fileno())


def _load_jsonl(path):
    if not os.path.exists(path):
        return []

    rows = []
    with open(path, "r", encoding="utf-8") as f:
        for line in f:
            line = line.strip()
            if line:
                rows.append(json.loads(line))
    return rows


def _load_checkpoint_df(path):
    rows = _load_jsonl(path)
    if not rows:
        return pd.DataFrame(
            columns=[
                "record_key",
                "flag",
                "reason",
                "corrected_first_name",
                "corrected_middle_name",
                "corrected_last_name",
            ]
        )

    checkpoint_df = pd.DataFrame(rows)

    if "record_key" not in checkpoint_df.columns:
        raise ValueError("Checkpoint file is missing 'record_key' column")

    checkpoint_df = checkpoint_df.drop_duplicates(subset=["record_key"], keep="last")
    return checkpoint_df


def build_batch_prompt(rows):
    payload = {
        "records": [
            {
                "encounter": int(row["encounter"]),
                "first_name": _safe_str(row["first_name"]),
                "middle_name": _safe_str(row["middle_name"]),
                "last_name": _safe_str(row["last_name"]),
            }
            for row in rows
        ]
    }

    return PROMPT_TMPL_BATCH.replace(
        "{Input}",
        json.dumps(payload, ensure_ascii=False, indent=2)
    )


async def review_batch(rows):
    prompt = build_batch_prompt(rows)

    response = await _call_llm_with_retry(
        hclient=hclient,
        schema=BatchNameCorrectionOutput,
        prompt=prompt,
        params={"qos": "accurate", "reasoning": "true"},
    )

    response = _to_dict(response)

    if "results" not in response:
        raise ValueError("LLM response does not contain 'results'")

    result_by_encounter = {}
    for item in response["results"]:
        encounter = int(item["encounter"])
        result_by_encounter[encounter] = item

    ordered_results = []
    for row in rows:
        encounter = int(row["encounter"])
        if encounter not in result_by_encounter:
            raise ValueError(f"Missing encounter {encounter} in batch response")
        ordered_results.append(result_by_encounter[encounter])

    return ordered_results


async def review_batch_safe(rows):
    try:
        batch_results = await review_batch(rows)
        return {
            "ok": True,
            "rows": rows,
            "batch_results": batch_results,
            "error": None,
        }
    except Exception as e:
        return {
            "ok": False,
            "rows": rows,
            "batch_results": None,
            "error": str(e),
        }


async def process_all_files_in_batches_resume(
    df,
    batch_size=10,
    max_concurrent_requests=5,
    checkpoint_path="name_audit_checkpoint.jsonl",
    failed_batches_path="name_audit_failed_batches.jsonl",
):
    working_df = df.copy().reset_index(drop=True)

    required_cols = ["file", "encounter", "first_name", "middle_name", "last_name"]
    missing_cols = [c for c in required_cols if c not in working_df.columns]
    if missing_cols:
        raise ValueError(f"Missing required columns: {missing_cols}")

    working_df["record_key"] = (
        working_df["file"].astype(str) + "|" + working_df["encounter"].astype(int).astype(str)
    )

    if working_df["record_key"].duplicated().any():
        dupes = working_df.loc[working_df["record_key"].duplicated(), ["file", "encounter"]]
        raise ValueError(
            "Duplicate file+encounter combinations found. "
            "Each encounter must be unique within a file.\n"
            f"Sample duplicates:\n{dupes.head()}"
        )

    checkpoint_df = _load_checkpoint_df(checkpoint_path)
    completed_keys = set(checkpoint_df["record_key"].tolist())

    pending_df = working_df[~working_df["record_key"].isin(completed_keys)].copy()

    print(f"Total rows in input: {len(working_df)}")
    print(f"Already completed from checkpoint: {len(completed_keys)}")
    print(f"Pending rows to process: {len(pending_df)}")

    if pending_df.empty:
        final_df = (
            working_df.merge(
                checkpoint_df,
                on="record_key",
                how="left",
            )
            .drop(columns=["record_key"])
            .reset_index(drop=True)
        )
        return final_df

    grouped = pending_df.groupby("file", sort=False, dropna=False)
    total_files = pending_df["file"].nunique(dropna=False)

    for file_id, file_df in tqdm(grouped, total=total_files, desc="Files"):
        file_records = file_df.to_dict("records")
        file_batches = list(_chunk_records(file_records, batch_size))

        for i in range(0, len(file_batches), max_concurrent_requests):
            batch_group = file_batches[i:i + max_concurrent_requests]

            batch_group_results = await asyncio.gather(
                *(review_batch_safe(batch_rows) for batch_rows in batch_group)
            )

            success_records = []
            failed_records = []

            for result in batch_group_results:
                if result["ok"]:
                    batch_rows = result["rows"]
                    batch_results = result["batch_results"]

                    for input_row, output_row in zip(batch_rows, batch_results):
                        success_records.append(
                            {
                                "record_key": input_row["record_key"],
                                "flag": output_row["flag"],
                                "reason": output_row["reason"],
                                "corrected_first_name": output_row["corrected_first_name"],
                                "corrected_middle_name": output_row["corrected_middle_name"],
                                "corrected_last_name": output_row["corrected_last_name"],
                            }
                        )
                else:
                    batch_rows = result["rows"]
                    failed_records.append(
                        {
                            "file": str(file_id),
                            "encounters": [int(r["encounter"]) for r in batch_rows],
                            "record_keys": [r["record_key"] for r in batch_rows],
                            "error": result["error"],
                        }
                    )

            if success_records:
                _append_jsonl(checkpoint_path, success_records)

            if failed_records:
                _append_jsonl(failed_batches_path, failed_records)

    checkpoint_df = _load_checkpoint_df(checkpoint_path)

    final_df = (
        working_df.merge(
            checkpoint_df,
            on="record_key",
            how="left",
        )
        .drop(columns=["record_key"])
        .reset_index(drop=True)
    )

    return final_df


final_df = await process_all_files_in_batches_resume(
    df,
    batch_size=10,
    max_concurrent_requests=5,
    checkpoint_path="name_audit_checkpoint.jsonl",
    failed_batches_path="name_audit_failed_batches.jsonl",
)
