from typing import List
from pydantic import BaseModel, Field, RootModel, ConfigDict, model_validator


class EncounterNameReview(BaseModel):
    model_config = ConfigDict(
        extra="forbid",
        strict=True,
        str_strip_whitespace=True
    )

    corrected_first_name: str = Field(
        description="Corrected first name. Copy original first_name if no correction is needed."
    )
    corrected_middle_name: str = Field(
        description="Corrected middle name. Use empty string if no middle name is present."
    )
    corrected_last_name: str = Field(
        description="Corrected last name. Copy original last_name if no correction is needed."
    )
    name_incorrect: bool = Field(
        description="True if first_name, middle_name, and last_name were incorrectly segmented or assigned."
    )
    name_incorrect_reason: str = Field(
        description='Short reason for name correction. Must be empty string if name_incorrect is false.'
    )
    name_mismatch: bool = Field(
        description="True if the corrected full name is clearly a different person from the batch majority."
    )
    name_mismatch_reason: str = Field(
        description='Short reason for mismatch. Must be empty string if name_mismatch is false.'
    )

    @model_validator(mode="after")
    def validate_reason_fields(self):
        if self.name_incorrect is False and self.name_incorrect_reason != "":
            raise ValueError("name_incorrect_reason must be empty when name_incorrect is false")

        if self.name_incorrect is True and self.name_incorrect_reason == "":
            raise ValueError("name_incorrect_reason must be provided when name_incorrect is true")

        if self.name_mismatch is False and self.name_mismatch_reason != "":
            raise ValueError("name_mismatch_reason must be empty when name_mismatch is false")

        if self.name_mismatch is True and self.name_mismatch_reason == "":
            raise ValueError("name_mismatch_reason must be provided when name_mismatch is true")

        return self


class EncounterNameReviewList(RootModel[List[EncounterNameReview]]):
    model_config = ConfigDict(
        extra="forbid",
        strict=True
    )
