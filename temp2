async def process_all_files_in_batches_parallel(df, batch_size=10, max_concurrent_requests=5):
    working_df = df.copy().reset_index(drop=False).rename(columns={"index": "__row_id"})

    duplicate_check = (
        working_df.groupby(["file", "encounter"])
        .size()
        .reset_index(name="cnt")
    )

    duplicates = duplicate_check[duplicate_check["cnt"] > 1]
    if not duplicates.empty:
        raise ValueError(
            "Duplicate encounter values found within the same file. "
            "Each encounter must be unique within a file."
        )

    all_outputs = []

    grouped = working_df.groupby("file", sort=False, dropna=False)
    total_files = working_df["file"].nunique(dropna=False)

    for file_id, file_df in tqdm(grouped, total=total_files, desc="Files"):
        file_records = file_df.to_dict("records")
        file_batches = list(_chunk_records(file_records, batch_size))

        for i in range(0, len(file_batches), max_concurrent_requests):
            batch_group = file_batches[i:i + max_concurrent_requests]

            batch_results_group = await asyncio.gather(
                *(review_batch(batch_rows) for batch_rows in batch_group)
            )

            for batch_rows, batch_results in zip(batch_group, batch_results_group):
                for input_row, output_row in zip(batch_rows, batch_results):
                    all_outputs.append(
                        {
                            "__row_id": input_row["__row_id"],
                            "flag": output_row["flag"],
                            "reason": output_row["reason"],
                            "corrected_first_name": output_row["corrected_first_name"],
                            "corrected_middle_name": output_row["corrected_middle_name"],
                            "corrected_last_name": output_row["corrected_last_name"],
                        }
                    )

    output_df = pd.DataFrame(all_outputs)

    final_df = (
        working_df.merge(output_df, on="__row_id", how="left")
        .sort_values("__row_id")
        .drop(columns="__row_id")
        .reset_index(drop=True)
    )

    return final_df
